# ─────────────────────────────────────────────────────────────────────────────
# EduBoost SA — Environment Variables Template
# Copy to .env and fill in your actual keys before running
# NEVER commit .env to source control
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_NAME=EduBoost SA
APP_VERSION=1.0.0
APP_PORT=8000
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-long-random-string

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
POSTGRES_DB=eduboost
POSTGRES_USER=eduboost_user
POSTGRES_PASSWORD=devpassword
DATABASE_URL=postgresql+asyncpg://eduboost_user:devpassword@localhost:5432/eduboost

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── AI — Primary (Groq: fast, free tier 14,400 req/day) ───────────────────────
# Get free key at: https://console.groq.com
GROQ_API_KEY=gsk_your-groq-api-key-here
GROQ_MODEL=llama3-70b-8192
GROQ_MAX_TOKENS=1800
GROQ_TEMPERATURE=0.65
GROQ_TIMEOUT_SECONDS=30
GROQ_DAILY_REQUEST_LIMIT=14400

# ── AI — Secondary (Anthropic Claude) ────────────────────────────────────────
# Get key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_MAX_TOKENS=1800

# ── AI — Fallback (HuggingFace) ───────────────────────────────────────────────
# Get free key at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_your-huggingface-token-here
HUGGINGFACE_MODEL=HuggingFaceH4/zephyr-7b-beta

# ── Security ──────────────────────────────────────────────────────────────────
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-64-char-hex-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24
# Must be exactly 32 characters
ENCRYPTION_KEY=change-me-32-chars-exactly!!!!!!
ENCRYPTION_SALT=change-me-salt

# ── Redis (Cache + Celery broker) ─────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://eduboost.co.za

# ── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN=
PROMETHEUS_ENABLED=true
GRAFANA_ADMIN_PASSWORD=admin

# ── Email (Celery background tasks) ───────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-api-key

# ── Feature Flags ────────────────────────────────────────────────────────────
FEATURE_VOICE_INPUT=true
FEATURE_OFFLINE_MODE=true
FEATURE_PARENT_REPORTS=true
FEATURE_RLHF_COLLECTION=true
FEATURE_LEARNING_STYLE_ML=true

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_LLM_PER_MINUTE=20
RATE_LIMIT_API_PER_MINUTE=100

# ── Fourth Estate / Constitutional Audit ─────────────────────────────────────
FOURTH_ESTATE_STREAM_KEY=eduboost:audit_stream
FOURTH_ESTATE_MAX_LEN=100000
ETHER_PROFILE_TTL=86400
